            "description": "",
            "rawdescription": "\n",
            "type": "component",
            "sourceCode": "import { Component, EventEmitter, Input, Output, forwardRef } from '@angular/core';\nimport { ControlValueAccessor, NG_VALUE_ACCESSOR } from '@angular/forms';\nimport { CommonModule } from '@angular/common';\n\n@Component({\n  selector: 'lib-radio-button',\n  standalone: true,\n  imports: [CommonModule],\n  templateUrl: './radiobutton.component.html',\n  providers: [\n    {\n      provide: NG_VALUE_ACCESSOR,\n      useExisting: forwardRef(() => RadioButtonComponent),\n      multi: true,\n    },\n  ],\n})\nexport class RadioButtonComponent implements ControlValueAccessor {\n  @Input() value!: string;\n  @Input() name!: string;\n  @Input() checked = false;  \n  @Input() disabled = false;  \n\n  @Output() selectionChange = new EventEmitter<string>(); \n  @Output() radioClick = new EventEmitter<Event>();  \n\n  onChangeFn: (value: string) => void = () => { console.log('Value changed:', this.value); };\n  onTouchedFn: () => void = () => { console.log('Touched'); };\n\n  writeValue(value: string): void {\n    this.checked = this.value === value;\n  }\n\n  registerOnChange(fn: (value: string) => void): void {\n    this.onChangeFn = fn;\n  }\n\n  registerOnTouched(fn: () => void): void {\n    this.onTouchedFn = fn;\n  }\n\n  setDisabledState(isDisabled: boolean): void {\n    this.disabled = isDisabled;\n  }\n\n  handleChange(event: Event): void {\n    console.log('Radio button changed:', event);\n    if (!this.disabled) {\n      this.onChangeFn(this.value);\n      this.selectionChange.emit(this.value);\n    }\n  }\n\n  handleClick(event: MouseEvent): void {\n    console.log('Radio button clicked:', event);\n    if (!this.disabled) {\n      this.radioClick.emit(event);\n    }\n  }\n}\n",
            "assetsDirs": [],
            "styleUrlsData": "",
            "stylesData": "",
            "extends": [],
            "implements": [
                "ControlValueAccessor"
            ],
            "templateData": "<label class=\"flex items-center space-x-2 cursor-pointer\">\n    <input\n      type=\"radio\"\n      [name]=\"name\"\n      [value]=\"value\"\n      [checked]=\"checked\"\n      [disabled]=\"disabled\"\n      (change)=\"handleChange()\"\n      (click)=\"handleClick()\"\n      class=\"hidden peer\"\n    />\n    <div\n      class=\"w-6 h-6 rounded-full border-2 border-gray-400 flex items-center justify-center \n             peer-checked:border-blue-900 peer-checked:border-4 \n             hover:border-blue-900 focus:ring-2 focus:ring-blue-300 transition-all\"\n    >\n      <div class=\"w-3.5 h-3.5 bg-blue-900 rounded-full\" [ngClass]=\"{'hidden': !checked}\"></div>\n    </div>\n    <ng-content></ng-content>\n</label>\n"
        }
    ],
